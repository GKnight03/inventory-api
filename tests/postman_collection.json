      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Returned product has correct fields\", function () {",
              "    const data = pm.response.json();",
              "    pm.expect(data).to.have.property(\"ProductID\");",
              "    pm.expect(data).to.have.property(\"Name\");",
              "    pm.expect(data).to.have.property(\"UnitPrice\");",
              "    pm.expect(data).to.have.property(\"StockQuantity\");",
              "    pm.expect(data).to.have.property(\"Description\");",
              "});"
            ]
          }
        }
      ],
      "response": []

  "item": [
    {
      "name": "Home",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/",
          "host": ["{{base_url}}"],
          "path": [""]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response is JSON\", function () {",
              "    pm.response.to.be.json;",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Add New Product",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"ProductID\": 20,\n  \"Name\": \"SSD\",\n  \"UnitPrice\": 89.99,\n  \"StockQuantity\": 7,\n  \"Description\": \"1TB SSD\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/addNew",
          "host": ["{{base_url}}"],
          "path": ["addNew"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Product added successfully\", function () {",
              "    const data = pm.response.json();",
              "    pm.expect(data.message).to.eql(\"Product added successfully\");",
              "    pm.expect(data.product).to.have.property(\"ProductID\");",
              "    pm.expect(data.product).to.have.property(\"Name\");",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Get Single Product",
      "request": {
        "method": "GET",
        "header": [],
